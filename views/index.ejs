<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Blog</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="#">My Blog</a>
    <a href="/NewArticle" class="btn btn-success">New Article</a>
  </div>
</nav>

<!-- Content -->
<div class="container mt-4">

   


  <% if (AAA.length == 0 ) { %>
   <h1>There no Articles So far</h1>
  <% } %>



    <% if (AAA.length > 0) { %>
       <h2 class="mb-4">Latest Articles</h2>

 


  <!-- Article Card -->
     <% AAA.reverse().forEach(item => { %>
     
  <div class="card mb-3 shadow-sm">
    <div class="card-body">
      <h5 class="card-title"><%= item.title %></h5>
      <p class="card-text"><%= item.Description %></p>

      <a href="/ShowArticle/<%= item._id  %>" class="btn btn-primary btn-sm">Read More</a>
      <a href="/edit/<%= item._id  %>" class="btn btn-warning btn-sm">Edit</a>
<form action="/articles/<%= item._id %>?_method=DELETE" method="POST" style="display:inline;">
  <button type="submit" class="btn btn-danger btn-sm">
    Delete
  </button>
</form> 
    </div>
  </div>
      <% }) %>

    <% } %>


</div>

</body>
</html>